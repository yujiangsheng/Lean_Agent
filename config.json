{
  "_comment": "Gauss 配置文件 (Configuration File)",
  "_version": "3.0.0",
  
  "llm": {
    "backend": "ollama",
    "model_name": "qwen3-coder:30b",
    "ollama_base_url": "http://127.0.0.1:11434",
    "device": "auto",
    "max_length": 4096,
    "temperature": 0.2,
    "top_p": 0.9
  },
  
  "lean": {
    "lean_executable": "lean",
    "lake_executable": "lake",
    "project_dir": "lean_project",
    "timeout": 120,
    "max_tactic_depth": 50,
    "use_mathlib": true
  },
  
  "proof_search": {
    "beam_width": 10,
    "max_iterations": 500,
    "max_depth": 20,
    "max_retries": 3,
    "premise_retrieval_k": 20
  },
  
  "conjecture": {
    "max_candidates": 100,
    "min_interestingness": 0.3,
    "domains": ["nat", "int", "list", "algebra"]
  }
}
